# Environment configuration for Spectra

# LLM API Keys — MiMo is primary, Claude is fallback
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
CLAUDE_API_KEY=your_claude_api_key_here

# Redis for inter-agent message bus
REDIS_URL=redis://localhost:6379/0

# Data source APIs
DEXSCREENER_API=https://api.dexscreener.com/latest

# Output channels
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# Agent settings
SCOUT_POLL_INTERVAL=30
ANALYST_MODEL=xiaomi/mimo-v2-pro
EXECUTOR_DIGEST_INTERVAL=3600